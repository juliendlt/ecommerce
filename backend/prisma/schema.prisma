generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// USERS
// ============================================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  role      Role     @default(CUSTOMER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]

  @@map("users")
}

enum Role {
  CUSTOMER
  ADMIN
}

// ============================================================
// CATEGORIES
// ============================================================

model Category {
  id   String @id @default(cuid())
  name String
  slug String @unique

  products Product[]

  @@map("categories")
}

// ============================================================
// PRODUCTS
// ============================================================

model Product {
  id               String   @id @default(cuid())
  slug             String   @unique
  name             String
  shortDescription String?
  description      String?
  basePrice        Decimal  @db.Decimal(10, 2)
  isActive         Boolean  @default(true)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  images       ProductImage[]
  optionGroups ProductOptionGroup[]
  orderItems   OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("products")
}

// ============================================================
// IMAGES
// ============================================================

model ProductImage {

  id String @id @default(cuid())

  productId String

  url String

  alt String?

  position Int


  // Nouvelle relation :
  // une image peut être associée à une option
  optionValueId String?
  product Product @relation(fields:[productId], references:[id], onDelete: Cascade)
  optionValue OptionValue? @relation(fields:[optionValueId], references:[id])

}

// ============================================================
// OPTIONS — BASE CENTRALISÉE
// ============================================================

// Table centrale : toutes tes valeurs d'options (tissus, couleurs, finitions…)
// Passer isAvailable = false rend la valeur indisponible sur TOUS les produits qui l'utilisent
model OptionValue {
  id          String  @id @default(cuid())
  label       String  // ex: "Liberty fleurs", "Wax bleu", "Lin naturel"
  type        String  // ex: "tissu", "couleur", "finition" — pour filtrer / afficher proprement
  priceOffSet Decimal  @db.Decimal(10, 2)
  isAvailable Boolean @default(true)

  // Groupes de produits qui utilisent cette valeur
  groups ProductOptionGroup[]
  images ProductImage[]
  
  @@map("option_values")
}

// Groupe d'options PAR PRODUIT
// ex: "Choix du tissu" sur le Tablier A, "Couleur des finitions" sur la Pochette B
model ProductOptionGroup {
  id        String @id @default(cuid())
  productId String
  position  Int    @default(0)

  product Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  values  OptionValue[] // valeurs centrales disponibles pour CE groupe sur CE produit

  @@map("product_option_groups")
}

// ============================================================
// ORDERS
// ============================================================

model Order {
  id     String      @id @default(cuid())
  userId String
  status OrderStatus @default(PENDING)

  subtotal     Decimal @db.Decimal(10, 2)
  shippingCost Decimal @default(0) @db.Decimal(10, 2)
  total        Decimal @db.Decimal(10, 2)

  shipAddress String?
  shipCity    String?
  shipPostal  String?
  shipCountry String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items   OrderItem[]
  payment Payment?

  @@map("orders")
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

// ============================================================
// ORDER ITEMS
// ============================================================

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  productId String

  // Snapshot au moment de l'achat — indépendant du produit live
  productName String
  productSlug String
  quantity    Int
  unitPrice   Decimal @db.Decimal(10, 2)
  total       Decimal @db.Decimal(10, 2)

  // Choix des options du client au moment de la commande
  // ex: { "Tissu": "Liberty fleurs", "Couleur des finitions": "Doré" }
  optionsSnapshot Json?

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("order_items")
}

// ============================================================
// PAYMENTS
// ============================================================

model Payment {
  id      String @id @default(cuid())
  orderId String @unique

  stripePaymentId String? @unique
  stripeSessionId String? @unique

  amount   Decimal @db.Decimal(10, 2)
  currency String  @default("eur")
  status   PaymentStatus @default(PENDING)
  method   String?

  paidAt    DateTime?
  createdAt DateTime  @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}
